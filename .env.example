# =============================================================================
# OpenSubtitles Scraper - Environment Configuration
# Copy this file to .env and adjust values as needed.
# =============================================================================

# --- Rate Limiting ---
# Minimum seconds between consecutive requests (per-second throttle).
# Default: 1.0  (max ~1 request per second)
SCRAPER_MIN_REQUEST_INTERVAL=1.0

# Maximum requests allowed within a 60-second sliding window.
# Default: 60
SCRAPER_RATE_LIMIT_PER_MINUTE=60

# --- Queue / Concurrency ---
# Maximum number of in-flight scraper requests the API will process at once.
# Additional requests are queued or rejected depending on SCRAPER_QUEUE_TIMEOUT.
# Default: 2
SCRAPER_MAX_INFLIGHT_REQUESTS=2

# Maximum number of concurrent outbound HTTP requests to opensubtitles.org.
# Default: 2
SCRAPER_MAX_CONCURRENT_REQUESTS=2

# Seconds to wait in queue before rejecting a request with HTTP 429.
# Set to 0 to reject immediately when busy (no queue).
# Default: 0
SCRAPER_QUEUE_TIMEOUT=0

# Seconds the client should wait before retrying after a 429 response.
# Returned in the Retry-After header.
# Default: 15
SCRAPER_RETRY_AFTER_SECONDS=15

# --- Retry / Backoff ---
# Maximum number of automatic retries for failed upstream requests
# (applies to 429, 500, 502, 503, 504 responses).
# Default: 2
SCRAPER_MAX_RETRIES=2

# Exponential backoff factor between retries (seconds).
# Retry delays: backoff * (2 ^ retry_number) e.g. 2, 4, 8 ...
# Default: 2
SCRAPER_RETRY_BACKOFF_FACTOR=2

# --- Connection Pool ---
# Maximum connection pools to cache.
# Default: 5
SCRAPER_MAX_POOL_CONNECTIONS=5

# Maximum connections per pool.
# Default: 3
SCRAPER_MAX_POOL_SIZE=3

# --- Timeouts ---
# HTTP request timeout in seconds.
# Default: 30
SCRAPER_REQUEST_TIMEOUT=30

# --- Maintenance ---
# Number of requests between automatic connection pool cleanup.
# Default: 20
SCRAPER_MAX_REQUESTS_BEFORE_CLEANUP=20

# --- FlareSolverr (optional Cloudflare bypass) ---
# FlareSolverr endpoint. When running via docker-compose, this is
# pre-configured to use the sidecar service. For bare-metal / local dev,
# point to your FlareSolverr instance. Leave unset to disable.
# Default: (unset)
# FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Timeout in seconds for FlareSolverr challenge resolution.
# FlareSolverr needs time to spin up a browser and solve the challenge.
# Must be >= 30; challenges frequently take 20-40s.
# Default: 60
# FLARESOLVERR_TIMEOUT=60
